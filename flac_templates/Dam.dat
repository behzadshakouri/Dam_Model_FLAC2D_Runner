 group ddrainage0
save grid.sav

;Branch 2:initial.sav
;-------initial-------
set gravity=9.807
set flow=off
water density=1000
set dyn=off
set echo off
call Ininv.fis
set cd back
set wth=0.0 k0x=0.5 k0z=0.5
Ininv
initial saturation 0.0 region 125,28
initial saturation 0.0 region 128,27
initial saturation 0.0 region 148,26
initial saturation 0.0 region 151,28
initial saturation 0.0  i 150 j 25
initial saturation 0.0  i 152 j 28
initial pp 0.0 region 125,28
initial pp 0.0 region 128,27
initial pp 0.0 region 148,26
initial pp 0.0 region 151,28
initial pp 0.0  i 150 j 25
initial pp 0.0  i 152 j 28
history 999 unbalanced
solve elastic
save initial.sav


;Branch 11:9lc_layer9.sav
;-------layer9-------
m m group ushell9
prop d d_shell b b_shell s s_shell c c_shell f f_shell dilation di_shell &
 tension t_shell por p_shell perm pe_shell group ushell9
m m group udrainage9
prop d d_drainage b b_drainage s s_drainage c c_drainage f f_drainage &
 dilation di_drainage tension t_drainage por p_drainage perm pe_drainage &
 group udrainage9
m m group ufilter9
prop d d_filter b b_filter s s_filter c c_filter f f_filter dilation &
 di_filter tension t_filter por p_filter perm pe_filter group ufilter9
m m group core9
prop d d_core b b_core s s_core c c_core f f_core dilation di_core tension &
 t_core por p_core perm pe_core group core9
m m group dfilter9
prop d d_filter b b_filter s s_filter c c_filter f f_filter dilation &
 di_filter tension t_filter por p_filter perm pe_filter group dfilter9
m m group ddrainage9
prop d d_drainage b b_drainage s s_drainage c c_drainage f f_drainage &
 dilation di_drainage tension t_drainage por p_drainage perm pe_drainage &
 group ddrainage9
m m group dshell9
prop d d_shell b b_shell s s_shell c c_shell f f_shell dilation di_shell &
 tension t_shell por p_shell perm pe_shell group dshell9
ini sat 0.0 i 1 273 j 30 103
solve
save 9lc_layer9.sav

;Branch 12:9lc_impound.sav
;-------impoundment-------
apply pp 1136827.44 var 0.0 -1136827.44 from 1,1 to 111,95
apply pp 0.0 from 207,44 to 273,29
set mechanical=off
set flow=on
water bulk=2e4
set fastwb=on
set step 100000000
solve
save 9lc_impound.sav

restore '9lc_impound.sav'
;Branch 0:9lc_watermech.sav

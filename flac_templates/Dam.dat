;Branch 1:9lc_getting_static_outputs.sav
;--------getting_static_outputs----------
call getting_static_outputs.fis
save 9lc_getting_static_outputs.sav

;Branch 2:9lc_dynamic.sav
; -------dynamic-------
water bulk 2e7
set dyn=on
set large
hist 100 read dam_motion.his
hist write 100 table 100
call filter.fis
set filter_in 100
set filter_out 101
set fc = 12.5
filter
call int.fis
set int_in 101
set int_out 102
integrate
set echo off
call baseline.fis
set itab_unc=102 itab_corr=120 drift=-0.0002 ttime=55.045 itab_cmot=104
baseline
hist write 104 table 104
initial xdisp 0 ydisp 0
initial xvel 0 yvel 0
history 1 dytime
set echo off
call strain_hist.fis
strain_hist
set echo off
call reldispx.fis
reldispx
set echo off
call inipp.fis
inipp
set echo off
call excpp.fis
excpp
history 5 dytime
history 7 vsxy i=139, j=38
history 8 str_77_20
history 9 reldispx
history 10 reldispy
history 11 excpp
history 12 pp i=100, j=38
history 13 esyy i=100, j=38
history 14 xaccel i=139, j=1
history 15 xaccel i=139, j=103
history 16 xaccel i=264, j=29
history 17 xaccel i=9, j=29
history 18 xvel i=139, j=1
history 19 xvel i=139, j=103
history 20 xvel i=264, j=29
history 21 xvel i=9, j=29
history 22 xvel i=139, j=38
history 23 xdisp i=139, j=1
history 24 xdisp i=139, j=103
history nstep 100
set step=10000000
set multistep=on
ini dy_damp hyst default -3.156 1.904
ini dy_damp rayleigh 0.002 1.0 stiffness
apply ffield
apply sxy Sxy_bedrock hist table 104 from 1,1 to 273,1
apply xquiet yquiet from 1,1 to 273,1
solve dytime 55.045
save 9lc_dynamic.sav

